---
import BaseLayout from "../layouts/BaseLayout.astro";
import { intro, proposalSections, signalNotes, site } from "../data/content";

const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={site.title} description={site.description}>
  <div class="page-shell">
    <header class="masthead" id="top">
      <div class="masthead-inner">
        <div class="masthead-copy">
          <p class="eyebrow">{site.eyebrow}</p>
          <h1 class="masthead-title">
            <span>The case for</span>
            <span>an AI Impact Board</span>
            <span>for Norfolk</span>
          </h1>
          <p class="masthead-note">{site.note}</p>
          <div class="masthead-actions">
            <a class="button button-solid" href={`${basePath}briefings/norfolk-ai-impact-board-proposal.docx`}>
              Download proposal
            </a>
            <a
              class="button button-accent"
              href={`${basePath}briefings/norfolk-ai-impact-board-presentation.pptx`}
              download="norfolk-ai-impact-board-presentation.pptx"
            >
              Download presentation
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="article-shell">
      <article class="proposal">
        <div class="proposal-intro">
          {intro.map((paragraph) => (
            <p class="lead">{paragraph}</p>
          ))}
        </div>

        {proposalSections.map((section, index) => (
          <>
            <section class="proposal-section" id={section.id}>
              <h2>{section.title}</h2>

              {section.paragraphs?.map((paragraph) => <p>{paragraph}</p>)}

              {section.list && (
                <ul class="proposal-list">
                  {section.list.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </section>

            {index === 3 && (
              <figure class="article-figure">
                <img
                  src={`${basePath}images/norfolk-hero-art.jpg`}
                  alt="Stylised illustration of Norfolk's civic, economic and physical landscape."
                  width="1600"
                  height="872"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
                <figcaption>Illustration of Norfolk's civic and economic landscape.</figcaption>
              </figure>
            )}
          </>
        ))}

        <section class="proposal-section" id="signals">
          <h2>Signals</h2>
          <div class="signal-list">
            {signalNotes.map((item) => (
              <article class="signal-row">
                <p class="signal-source">{item.source}</p>
                <div>
                  <p class="signal-label">{item.label}</p>
                  <h3>
                    <a href={item.href} target="_blank" rel="noreferrer">{item.title}</a>
                  </h3>
                  <p>{item.text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <footer class="proposal-footer">
          <p>
            Proposed by Patrick Hussey, Founder
            <a href="https://www.goodtransformer.ai/" target="_blank" rel="noreferrer">@GoodTransformer</a>
          </p>
        </footer>
      </article>
    </main>
  </div>

</BaseLayout>
